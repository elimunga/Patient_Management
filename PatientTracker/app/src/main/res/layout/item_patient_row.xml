<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView android:id="@+id/tvRowName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:textColor="#000000"/>
        <TextView android:id="@+id/tvRowAge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.5" android:textColor="#000000"/>
        <TextView android:id="@+id/tvRowBmi" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#000000"/>
        <TextView android:id="@+id/tvRowDate" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#000000" android:textSize="12sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

</LinearLayout>