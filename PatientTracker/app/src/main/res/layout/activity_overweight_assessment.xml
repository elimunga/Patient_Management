<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:contentPadding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overweight Assessment"
                android:textAlignment="center"
                android:textColor="@color/medical_blue_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Patient ID">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOwPatientId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Visit Date (YYYY-MM-DD)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOwVisitDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView android:text="General Health" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_light" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgOwHealth" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <RadioButton android:id="@+id/rbOwHealthGood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Good" android:buttonTint="@color/medical_blue"/>
                <RadioButton android:id="@+id/rbOwHealthPoor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Poor" android:buttonTint="@color/medical_blue" android:layout_marginStart="16dp"/>
            </RadioGroup>

            <TextView android:text="Ever been on a diet to lose weight?" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_light" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgOwDiet" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <RadioButton android:id="@+id/rbDietYes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Yes" android:buttonTint="@color/medical_blue"/>
                <RadioButton android:id="@+id/rbDietNo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No" android:buttonTint="@color/medical_blue" android:layout_marginStart="16dp"/>
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Physician Comments">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOwComments"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitOw"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Submit Assessment"
                android:textSize="16sp"
                app:cornerRadius="8dp"
                app:backgroundTint="@color/medical_blue" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>